# Auto detect text files and perform LF normalization
* text=auto

# Brand asset hashes are byte-for-byte checks; keep SVG sources stable on Windows.
*.svg text eol=lf

# Fix GitHub language detection — mark generated/vendored files
src/index.html linguist-documentation
src/splash.html linguist-documentation
electron-app/splash.html linguist-documentation
*.lock linguist-generated
package-lock.json linguist-generated
