# Shared publication-data workflow constants.
#
# Shell entry points source this file when present. Python scripts read these
# values through environment variables and otherwise fall back to the same
# defaults.

PHYLOMOVIES_PUBLICATION_ENV=phylomovies-publication

BOOTSTRAP_SOURCE_ROOT=publication_data/bootstrap_rogue_taxa/source_alignments
BOOTSTRAP_DATASET_24=aberer_roguenarok_dataset_24_taxa24_sites14190.phy
BOOTSTRAP_DATASET_125=aberer_roguenarok_dataset_125_taxa125_sites29149.phy
BOOTSTRAP_OUTPUT_BASE=publication_data/bootstrap_rogue_taxa/runs
BOOTSTRAP_REPLICATES=200
BOOTSTRAP_SEED=42

RECAN_CANONICAL_ALIGNMENT=publication_data/recombination_norovirus/source_alignments/norovirus_trimmed_publication_alignment_334taxa_8058bp.fasta
RECAN_WORKING_SUBSET=publication_data/recombination_norovirus/source_alignments/recan_working_subset_48taxa_8058bp.fasta
RECAN_FOCUSED_SUBSET=publication_data/recombination_norovirus/source_alignments/recan_focused_subset_6taxa_8058bp.fasta
RECAN_OUTPUT_BASE=publication_data/recombination_norovirus/runs
RECAN_QUERY_ID=MK753032_P16_GII-4
RECAN_WINDOW_SIZE=500
RECAN_STEP_SIZE=250
RECAN_DISTANCE_METHOD=pdist
RECAN_ORF_JUNCTION=5000
RECAN_REPS_PER_COMBO=5
RECAN_MAX_GAP_PERCENT=7.0
RECAN_FOCUSED_SELECTED_IDS=PV588655_P17_GII-17,PV588657_P17_GII-17,PV746275_P16_GII-4,MH218629_P31_GII-4,OR536471_P21_GII-3,MW305600_P21_GII-2
