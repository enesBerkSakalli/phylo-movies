# Third-party/raw datasets are not stored wholesale in this repository.
# Add only explicitly selected files, with provenance, when they are needed.
original_online_data/
external_raw/
selected_external_files/*
!selected_external_files/README.md

# Local generated outputs from the EPAS1 helper pipeline.
epas1_pipeline/data/
epas1_pipeline/out/
epas1_pipeline/.snakemake/
epas1_pipeline/__pycache__/
epas1_pipeline/scripts/__pycache__/
epas1_pipeline/bootstrap_bridge/__pycache__/
epas1_pipeline/helpers/__pycache__/
epas1_pipeline/legacy/__pycache__/
