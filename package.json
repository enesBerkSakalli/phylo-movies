{
  "name": "phylo-movies-frontend",
  "version": "0.64.0",
  "description": "PhyloMovies is a browser-based phylogenetic tree viewer with morphing animations for computational biologists.",
  "author": "Enes Berk Sakalli <enes.sakalli@univie.ac.at>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/enesBerkSakalli/phylo-movies.git"
  },
  "bugs": {
    "url": "https://github.com/enesBerkSakalli/phylo-movies/issues"
  },
  "homepage": "https://github.com/enesBerkSakalli/phylo-movies#readme",
  "keywords": [
    "phylogenetics",
    "visualization",
    "bioinformatics",
    "react",
    "WebGL",
    "deck.gl"
  ],
  "private": true,
  "scripts": {
    "postinstall": "bash scripts/check-submodule.sh",
    "dev": "node scripts/run-vite-clean.mjs",
    "build": "node scripts/run-vite-clean.mjs build && ./scripts/copy-examples.sh dist",
    "lint": "eslint src test scripts vite.config.mts vitest.config.js",
    "preview": "node scripts/run-vite-clean.mjs preview",
    "test": "npm run test:all",
    "test:all": "npm run test:structure && npm run test:mocha && npm run test:vitest && npm run test:optional",
    "test:mocha": "mocha --require @babel/register 'test/fileUpload.test.js' 'test/parser.test.js' 'test/integration.test.js' 'test/deck-timeline-renderer.test.js' 'test/timeline-construction.test.js' 'test/timeline-math-utils.test.js' 'test/segment-timing.test.js' 'test/scrubber-api.test.js' 'test/timeline-manager-lifecycle.test.js' 'test/timeline-navigation-controller.test.js' 'test/interpolation-cache-reset.test.js'",
    "test:optional": "for f in test/optional/*.test.js; do NODE_OPTIONS=--no-warnings mocha --require @babel/register \"$f\" || exit 1; done",
    "test:watch": "mocha --require @babel/register --watch 'test/fileUpload.test.js' 'test/parser.test.js' 'test/integration.test.js' 'test/deck-timeline-renderer.test.js' 'test/timeline-construction.test.js' 'test/timeline-math-utils.test.js' 'test/segment-timing.test.js' 'test/scrubber-api.test.js' 'test/timeline-manager-lifecycle.test.js' 'test/timeline-navigation-controller.test.js' 'test/interpolation-cache-reset.test.js'",
    "build:gh": "VITE_DOCS_ONLY=true node scripts/run-vite-clean.mjs build --base=/phylo-movies/ && VITE_DOCS_ONLY=true node scripts/apply-gh-seo.js dist && ./scripts/copy-examples.sh dist",
    "copy-examples": "./scripts/copy-examples.sh dist",
    "test:backend-required": "mocha --require @babel/register 'test/integration.test.js'",
    "test:unit": "mocha --require @babel/register 'test/parser.test.js' 'test/fileUpload.test.js'",
    "test:vitest": "vitest run",
    "test:list": "node scripts/list-tests.js",
    "test:structure": "node scripts/list-tests.js --check",
    "dev:electron": "cd electron-app && npm run dev"
  },
  "dependencies": {
    "@deck.gl/core": "9.2.5",
    "@deck.gl/extensions": "9.2.5",
    "@deck.gl/layers": "9.2.5",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@vitejs/plugin-react": "^4.5.0",
    "bezier-js": "^6.1.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "colorjs.io": "^0.6.1",
    "d3-array": "^3.2.4",
    "d3-hierarchy": "^3.1.2",
    "d3-scale-chromatic": "^3.1.0",
    "localforage": "^1.10.0",
    "lucide-react": "^0.562.0",
    "memoize-one": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-draggable": "^4.5.0",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.63.0",
    "react-rnd": "^10.5.2",
    "react-router-dom": "^7.10.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.76",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.26.3",
    "@babel/register": "^7.27.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^24.6.0",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "chai": "^4.5.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "mocha": "^10.8.2",
    "proxyquire": "^2.1.3",
    "sass": "^1.89.1",
    "sinon": "^17.0.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^5.4.20",
    "vitest": "^3.2.4"
  }
}
