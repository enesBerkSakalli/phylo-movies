# Phylo-Movies local environment template.
# Copy to .env.local only when you need to override defaults.

# Vite variables
# Builds the documentation-only GitHub Pages app when set to true.
VITE_DOCS_ONLY=false

# Electron build flag. Normally set by electron-app/package.json scripts.
ELECTRON_BUILD=false

# Flask backend variables
# Development defaults are defined in engine/BranchArchitect/webapp/config.py.
FLASK_DEBUG=1
CORS_ORIGINS=*
LOG_LEVEL=INFO

# Optional Flask secret. If unset, the backend generates a random key at startup.
SECRET_KEY=

# Optional tree inference binary overrides.
# Source/dev runs first honor these paths, then bundled binaries, then system PATH.
IQTREE_PATH=
FASTTREE_PATH=

# Publication-data regeneration profile used by docker-compose publication tools.
PHYLOMOVIES_PUBLICATION_ENV=phylomovies-publication
