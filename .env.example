# PhyloMovies knowledge wiki environment template.
# Copy to .env.local for local use. Do not commit real secrets.

# Runtime mode for wiki scripts and local experiments.
KNOWLEDGE_ENV=local

# Stable installation identifier for this local wiki checkout.
# Generate with:
#   node -e "console.log(crypto.randomUUID())"
KNOWLEDGE_INSTANCE_ID=00000000-0000-4000-8000-000000000000

# Optional namespace used when generating source, page, and run IDs.
KNOWLEDGE_ID_NAMESPACE=phylo-movies

# Optional local paths for raw and generated knowledge.
KNOWLEDGE_ROOT=knowledge
KNOWLEDGE_SOURCES_DIR=knowledge/sources
KNOWLEDGE_WIKI_DIR=knowledge/wiki

# Optional LLM provider keys. Leave blank unless you install tooling that uses them.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# Optional OpenAI-compatible local or proxy endpoint.
# Ollama default OpenAI-compatible endpoint:
#   http://localhost:11434/v1
# LiteLLM proxy default is commonly:
#   http://localhost:4000/v1
OPENAI_BASE_URL=

# Optional model choices for wiki operations.
KNOWLEDGE_LLM_MODEL=
KNOWLEDGE_EMBEDDING_MODEL=
KNOWLEDGE_RERANK_MODEL=

# Optional QMD settings.
QMD_COLLECTION=phylo-movies-knowledge
QMD_INDEX_DIR=.qmd

# Optional local secret for signing internal run manifests.
# Generate with:
#   openssl rand -hex 32
KNOWLEDGE_RUN_SIGNING_SECRET=

# Optional symmetric key for encrypting local generated exports.
# Generate with:
#   openssl rand -base64 32
KNOWLEDGE_EXPORT_ENCRYPTION_KEY=
